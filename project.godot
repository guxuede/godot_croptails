; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="Croptails"
run/main_scene="uid://lbu5loesr2ao"
config/features=PackedStringArray("4.6", "Forward Plus")
config/icon="res://icon.svg"

[audio]

buses/default_bus_layout="uid://bv7y37a1rokmp"

[autoload]

ToolManager="*uid://ba62s3yu8xfiu"
InventoryManager="*uid://r1p7emihqek3"
DayAndNightManager="*uid://b7n40oj22q2m8"
DialogueManager="*uid://c3rodes2l3gxb"
GameDialogueManager="*uid://dl788fgvbfsjf"
GameManager="*uid://bxsbca7245tyr"
SceneManager="*uid://0pojcm56sna6"
UiManager="*uid://72ge47l0jiwl"
Global="*uid://nng3t6lyuiki"
FootSoundManager="*uid://dvw8ouytmbn6d"

[display]

window/size/viewport_width=640
window/size/viewport_height=360
window/size/window_width_override=1280
window/size/window_height_override=720
window/stretch/mode="canvas_items"
window/stretch/aspect="keep_height"
window/stretch/scale_mode="integer"

[editor_plugins]

enabled=PackedStringArray("res://addons/dialogue_manager/plugin.cfg", "res://addons/gloot/plugin.cfg")

[file_customization]

folder_colors={
"res://assets/": "orange",
"res://audio/": "red",
"res://dialogue/": "blue",
"res://scenes/": "green",
"res://scripts/": "pink",
"res://tilesets/": "yellow"
}

[global_group]

navigation_polygon_source_geometry_group=""
player=""

